# Frontend environment variables.
# Copy to `.env` and adjust as needed. Vite only exposes vars prefixed VITE_.

# Base URL of the backend prediction API. During `npm run dev` the Vite proxy
# forwards /api -> http://localhost:8000, so this default works without changes.
# For a production build pointed at a different host, set this explicitly.
VITE_API_BASE=http://localhost:8000/api/v1
